<launch>
  <!-- Arguments -->
  <arg name="slam_methods" default="gmapping" doc="slam type [gmapping, cartographer, hector, karto, frontier_exploration]"/>
  <arg name="configuration_basename" default="scuttle_lds_2d.lua"/>

  <!-- SLAM: Gmapping, Cartographer, Hector, Karto, Frontier_exploration, RTAB-Map -->
  <include file="$(find scuttle_slam)/launch/scuttle_$(arg slam_methods).launch">
    <arg name="configuration_basename" value="$(arg configuration_basename)"/>
  </include>

  <!-- RViz: Load scuttle_gmapping.rviz automatically -->
  <node pkg="rviz" type="rviz" name="rviz" 
        args="-d $(find scuttle_slam)/rviz/scuttle_gmapping.rviz" 
        output="screen" />

</launch>
