<?xml version="1.0"?>
<robot name="nox">
    <link name="base_link">
    </link>

    <link name="laser">
    </link>
    <!--
    <link name="odom"/>
    -->
    <joint name="base_link_to_laser" type="fixed">
        <parent link="base_link"/>
        <child link="laser"/>
        <origin xyz="0.0 0.0 0.3" rpy="0.0 0.0 0.0"/>
        <axis xyz="0 0 0"/>
    </joint>
    <!--
    <joint name="odom_to_base" type="fixed">
         <parent link="odom"/>
         <child link="base_link"/>
         <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    -->


</robot>
